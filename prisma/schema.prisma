
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model TodoLists { 
  id              Int      @id @default(autoincrement()) 
  title           String   
  description     String?
  color           Role     @default(ORANGE) 
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
} 


enum Role { 
  GREEN 
  RED
  ORANGE

} 